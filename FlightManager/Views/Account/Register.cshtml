@model FlightManager.Web.ViewModels.Account.RegisterViewModel
@{
    ViewData["Title"] = "Регистрация";
}

<div class="row justify-content-center">
    <div class="col-md-7">
        <div class="card shadow-sm border-0 mt-4">
            <div class="card-body p-4">
                <h2 class="card-title text-center mb-1">Регистрация</h2>
                <p class="text-center text-muted small mb-4">Създайте нов акаунт</p>

                <form asp-action="Register" asp-controller="Account" method="post">
                    <div asp-validation-summary="ModelOnly" class="alert alert-danger py-2 small" role="alert"></div>

                    <div class="row">
                        <div class="col-md-6 mb-3">
                            <label asp-for="FirstName" class="form-label fw-semibold">Първо име</label>
                            <input asp-for="FirstName" class="form-control" placeholder="Иван" />
                            <span asp-validation-for="FirstName" class="text-danger small"></span>
                        </div>
                        <div class="col-md-6 mb-3">
                            <label asp-for="LastName" class="form-label fw-semibold">Фамилия</label>
                            <input asp-for="LastName" class="form-control" placeholder="Иванов" />
                            <span asp-validation-for="LastName" class="text-danger small"></span>
                        </div>
                    </div>

                    <div class="mb-3">
                        <label asp-for="Email" class="form-label fw-semibold">Имейл</label>
                        <input asp-for="Email" class="form-control" placeholder="example@mail.com" autocomplete="email" />
                        <span asp-validation-for="Email" class="text-danger small"></span>
                    </div>

                    <div class="row">
                        <div class="col-md-6 mb-3">
                            <label asp-for="Password" class="form-label fw-semibold">Парола</label>
                            <input asp-for="Password" class="form-control" placeholder="••••••••" autocomplete="new-password" />
                            <span asp-validation-for="Password" class="text-danger small"></span>
                        </div>
                        <div class="col-md-6 mb-3">
                            <label asp-for="ConfirmPassword" class="form-label fw-semibold">Потвърди парола</label>
                            <input asp-for="ConfirmPassword" class="form-control" placeholder="••••••••" autocomplete="new-password" />
                            <span asp-validation-for="ConfirmPassword" class="text-danger small"></span>
                        </div>
                    </div>

                    <div class="mb-3">
                        <label asp-for="EGN" class="form-label fw-semibold">ЕГН</label>
                        <input asp-for="EGN" class="form-control" placeholder="10 цифри" maxlength="10" />
                        <span asp-validation-for="EGN" class="text-danger small"></span>
                    </div>

                    <div class="mb-3">
                        <label asp-for="PhoneNumber" class="form-label fw-semibold">Телефон <span class="text-muted fw-normal">(незадължително)</span></label>
                        <input asp-for="PhoneNumber" class="form-control" placeholder="+359..." />
                        <span asp-validation-for="PhoneNumber" class="text-danger small"></span>
                    </div>

                    <div class="mb-4">
                        <label asp-for="Address" class="form-label fw-semibold">Адрес <span class="text-muted fw-normal">(незадължително)</span></label>
                        <input asp-for="Address" class="form-control" placeholder="гр. София, ул. ..." />
                        <span asp-validation-for="Address" class="text-danger small"></span>
                    </div>

                    <div class="d-grid mb-3">
                        <button type="submit" class="btn btn-primary">Регистрирай се</button>
                    </div>

                    <div class="text-center small">
                        Вече имате акаунт?
                        <a asp-action="Login" asp-controller="Account">Влезте тук</a>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{ await Html.RenderPartialAsync("_ValidationScriptsPartial"); }
}
