@{
    ViewData["Title"] = "Проверете имейла си";
}

<div class="row justify-content-center">
    <div class="col-md-5">
        <div class="card shadow-sm border-0 mt-4 text-center">
            <div class="card-body p-5">
                <div class="mb-3" style="font-size: 3rem;">✉️</div>
                <h2 class="card-title mb-2">Проверете имейла си</h2>
                <p class="text-muted">
                    Ако акаунт с този имейл адрес съществува, ще получите линк за възстановяване на паролата.
                </p>
                <a asp-action="Login" asp-controller="Account" class="btn btn-outline-primary mt-2">
                    Обратно към вход
                </a>
            </div>
        </div>
    </div>
</div>
