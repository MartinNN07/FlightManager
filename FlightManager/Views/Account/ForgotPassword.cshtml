@model FlightManager.Web.ViewModels.Account.ForgotPasswordViewModel
@{
    ViewData["Title"] = "Забравена парола";
}

<div class="row justify-content-center">
    <div class="col-md-5">
        <div class="card shadow-sm border-0 mt-4">
            <div class="card-body p-4">
                <h2 class="card-title text-center mb-1">Забравена парола</h2>
                <p class="text-center text-muted small mb-4">
                    Въведете имейл адреса си и ще получите линк за смяна на паролата.
                </p>

                <form asp-action="ForgotPassword" asp-controller="Account" method="post">
                    <div asp-validation-summary="ModelOnly" class="alert alert-danger py-2 small" role="alert"></div>

                    <div class="mb-3">
                        <label asp-for="Email" class="form-label fw-semibold">Имейл</label>
                        <input asp-for="Email" class="form-control" placeholder="example@mail.com" autocomplete="email" />
                        <span asp-validation-for="Email" class="text-danger small"></span>
                    </div>

                    <div class="d-grid mb-3">
                        <button type="submit" class="btn btn-primary">Изпрати линк</button>
                    </div>

                    <div class="text-center small">
                        <a asp-action="Login" asp-controller="Account">← Обратно към вход</a>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{ await Html.RenderPartialAsync("_ValidationScriptsPartial"); }
}
