@{
    ViewData["Title"] = "Достъпът е отказан";
}

<div class="row justify-content-center">
    <div class="col-md-5">
        <div class="card shadow-sm border-0 mt-4 text-center">
            <div class="card-body p-5">
                <div class="mb-3" style="font-size: 3rem;">🚫</div>
                <h2 class="card-title mb-2">Достъпът е отказан</h2>
                <p class="text-muted">
                    Нямате права за достъп до тази страница.
                    Моля, влезте с подходящ акаунт или се свържете с администратор.
                </p>
                <div class="d-flex justify-content-center gap-2 mt-3">
                    <a asp-controller="Home" asp-action="Index" class="btn btn-outline-secondary">← Начало</a>
                    <a asp-action="Login" asp-controller="Account" class="btn btn-primary">Вход</a>
                </div>
            </div>
        </div>
    </div>
</div>
