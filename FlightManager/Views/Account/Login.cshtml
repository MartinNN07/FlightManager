@model FlightManager.Web.ViewModels.Account.LoginViewModel
@{
    ViewData["Title"] = "Вход";
}

<div class="row justify-content-center">
    <div class="col-md-5">
        <div class="card shadow-sm border-0 mt-4">
            <div class="card-body p-4">
                <h2 class="card-title text-center mb-1">Вход</h2>
                <p class="text-center text-muted small mb-4">Влезте в своя акаунт</p>

                <form asp-action="Login" asp-controller="Account" method="post">
                    <input type="hidden" asp-for="ReturnUrl" />
                    <div asp-validation-summary="ModelOnly" class="alert alert-danger py-2 small" role="alert"></div>

                    <div class="mb-3">
                        <label asp-for="Email" class="form-label fw-semibold">Имейл</label>
                        <input asp-for="Email" class="form-control" placeholder="example@mail.com" autocomplete="email" />
                        <span asp-validation-for="Email" class="text-danger small"></span>
                    </div>

                    <div class="mb-3">
                        <label asp-for="Password" class="form-label fw-semibold">Парола</label>
                        <input asp-for="Password" class="form-control" placeholder="••••••••" autocomplete="current-password" />
                        <span asp-validation-for="Password" class="text-danger small"></span>
                    </div>

                    <div class="mb-3 form-check">
                        <input asp-for="RememberMe" class="form-check-input" />
                        <label asp-for="RememberMe" class="form-check-label">Запомни ме</label>
                    </div>

                    <div class="d-grid mb-3">
                        <button type="submit" class="btn btn-primary">Вход</button>
                    </div>

                    <div class="text-center small">
                        <a asp-action="ForgotPassword" asp-controller="Account">Забравена парола?</a>
                        &nbsp;|&nbsp;
                        <a asp-action="Register" asp-controller="Account">Нямате акаунт? Регистрирайте се</a>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{ await Html.RenderPartialAsync("_ValidationScriptsPartial"); }
}
