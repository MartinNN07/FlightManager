@model FlightManager.Web.ViewModels.Account.ResetPasswordViewModel
@{
    ViewData["Title"] = "Смяна на парола";
}

<div class="row justify-content-center">
    <div class="col-md-5">
        <div class="card shadow-sm border-0 mt-4">
            <div class="card-body p-4">
                <h2 class="card-title text-center mb-1">Смяна на парола</h2>
                <p class="text-center text-muted small mb-4">Въведете и потвърдете новата си парола.</p>

                <form asp-action="ResetPassword" asp-controller="Account" method="post">
                    <input type="hidden" asp-for="Code" />
                    <input type="hidden" asp-for="Email" />
                    <div asp-validation-summary="ModelOnly" class="alert alert-danger py-2 small" role="alert"></div>

                    <div class="mb-3">
                        <label asp-for="Password" class="form-label fw-semibold">Нова парола</label>
                        <input asp-for="Password" class="form-control" placeholder="••••••••" autocomplete="new-password" />
                        <span asp-validation-for="Password" class="text-danger small"></span>
                    </div>

                    <div class="mb-4">
                        <label asp-for="ConfirmPassword" class="form-label fw-semibold">Потвърди парола</label>
                        <input asp-for="ConfirmPassword" class="form-control" placeholder="••••••••" autocomplete="new-password" />
                        <span asp-validation-for="ConfirmPassword" class="text-danger small"></span>
                    </div>

                    <div class="d-grid">
                        <button type="submit" class="btn btn-primary">Смяна на парола</button>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{ await Html.RenderPartialAsync("_ValidationScriptsPartial"); }
}
