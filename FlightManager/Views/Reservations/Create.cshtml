@using FlightManager.Data.Models
@model FlightManager.Web.ViewModels.Reservations.ReservationCreateViewModel

@{
    ViewData["Title"] = "Добави резервация";
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <h2>@ViewData["Title"]</h2>
    <a asp-action="Index" class="btn btn-outline-secondary">
        <i class="bi bi-arrow-left"></i> Назад към списъка
    </a>
</div>

<div class="row">
    <div class="col-md-6">
        <form asp-action="Create" method="post">
            @Html.AntiForgeryToken()

            <div asp-validation-summary="ModelOnly" class="alert alert-danger" role="alert"></div>

            <div class="mb-3">
                <label asp-for="ContactEmail" class="form-label"></label>
                <input asp-for="ContactEmail" class="form-control" type="email" />
                <span asp-validation-for="ContactEmail" class="text-danger small"></span>
            </div>

            <div class="mb-3">
                <label asp-for="FlightId" class="form-label"></label>
                <input asp-for="FlightId" class="form-control" />
                <span asp-validation-for="FlightId" class="text-danger small"></span>
                @* Note: If you want a dropdown for flights, you will need to pass a SelectList from the controller and use <select asp-for="FlightId" asp-items="..."></select> *@
            </div>

            <div class="mb-3">
                <label asp-for="SeatClass" class="form-label"></label>
                <select asp-for="SeatClass" asp-items="Html.GetEnumSelectList<SeatingClass>()" class="form-select"></select>
                <span asp-validation-for="SeatClass" class="text-danger small"></span>
            </div>

            <div class="d-flex gap-2">
                <button type="submit" class="btn btn-primary">
                    <i class="bi bi-plus-lg"></i> Създай
                </button>
                <a asp-action="Index" class="btn btn-outline-secondary">Отказ</a>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}