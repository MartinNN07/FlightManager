@using FlightManager.Data.Models
@model FlightManager.Web.ViewModels.Reservations.ReservationCreateViewModel

@{
    ViewData["Title"] = "Добави резервация";

    if (Model.Passengers == null)
    {
        Model.Passengers = new List<FlightManager.Web.ViewModels.Reservations.PassengerInputModel>();
    }
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h2>@ViewData["Title"]</h2>
    <a asp-action="Index" class="btn btn-outline-secondary">
        <i class="bi bi-arrow-left"></i> Назад към списъка
    </a>
</div>

<form asp-action="Create" method="post" id="reservationForm">
    @Html.AntiForgeryToken()

    <div asp-validation-summary="ModelOnly" class="alert alert-danger" role="alert"></div>

    @* ════ СЕКЦИЯ: ПОЛЕТ ════ *@
    <div class="card mb-4 shadow-sm">
        <div class="card-header bg-primary text-white">
            <i class="bi bi-airplane-fill me-2"></i> Информация за полета
        </div>
        <div class="card-body">

            <div class="mb-3">
                <label asp-for="FlightId" class="form-label fw-semibold"></label>
                <div class="input-group">
                    <span class="input-group-text"><i class="bi bi-hash"></i></span>
                    <select asp-for="FlightId"
                            asp-items="ViewBag.FlightId"
                            class="form-select"
                            id="flightSelect">
                        <option value="">-- Изберете полет --</option>
                    </select>
                </div>
                <span asp-validation-for="FlightId" class="text-danger small"></span>
            </div>

            <div id="flightInfo" class="row g-3 mt-1" style="display:none !important;">
                <div class="col-md-4">
                    <div class="p-3 border rounded bg-light text-center">
                        <div class="text-muted small mb-1"><i class="bi bi-geo-alt-fill text-primary"></i> Град на излитане</div>
                        <div class="fw-bold" id="departureCity">—</div>
                    </div>
                </div>
                <div class="col-md-4">
                    <div class="p-3 border rounded bg-light text-center">
                        <div class="text-muted small mb-1"><i class="bi bi-geo-fill text-danger"></i> Град на кацане</div>
                        <div class="fw-bold" id="arrivalCity">—</div>
                    </div>
                </div>
                <div class="col-md-4">
                    <div class="p-3 border rounded bg-light text-center">
                        <div class="text-muted small mb-1"><i class="bi bi-calendar-event text-success"></i> Дата на полета</div>
                        <div class="fw-bold" id="flightDate">—</div>
                    </div>
                </div>
            </div>

        </div>
    </div>

    @* ════ СЕКЦИЯ: РЕЗЕРВАЦИЯ ════ *@
    <div class="card mb-4 shadow-sm">
        <div class="card-header bg-secondary text-white">
            <i class="bi bi-ticket-perforated-fill me-2"></i> Детайли на резервацията
        </div>
        <div class="card-body row g-3">

            <div class="col-md-6">
                <label asp-for="SeatClass" class="form-label fw-semibold"></label>
                <div class="d-flex gap-3 mt-1">
                    <div class="form-check form-check-inline">
                        @* FIXED: Removed the manual C# 'checked' attribute. asp-for does this automatically *@
                        <input class="form-check-input" type="radio" asp-for="SeatClass"
                               id="seatEconomy" value="@SeatingClass.Economy" />
                        <label class="form-check-label" for="seatEconomy">
                            <i class="bi bi-person-seat me-1"></i> Икономична
                        </label>
                    </div>
                    <div class="form-check form-check-inline">
                        @* FIXED: Removed the manual C# 'checked' attribute. asp-for does this automatically *@
                        <input class="form-check-input" type="radio" asp-for="SeatClass"
                               id="seatBusiness" value="@SeatingClass.Business" />
                        <label class="form-check-label" for="seatBusiness">
                            <i class="bi bi-star-fill me-1 text-warning"></i> Бизнес
                        </label>
                    </div>
                </div>
                <span asp-validation-for="SeatClass" class="text-danger small"></span>
            </div>

            <div class="col-md-6">
                <label asp-for="ContactEmail" class="form-label fw-semibold"></label>
                <div class="input-group">
                    <span class="input-group-text"><i class="bi bi-envelope-fill"></i></span>
                    <input asp-for="ContactEmail" class="form-control" type="email" placeholder="example@mail.com" />
                </div>
                <span asp-validation-for="ContactEmail" class="text-danger small"></span>
            </div>

        </div>
    </div>

    @* ════ СЕКЦИЯ: ПЪТНИЦИ ════ *@
    <div class="card mb-4 shadow-sm">
        <div class="card-header bg-success text-white d-flex justify-content-between align-items-center">
            <span><i class="bi bi-people-fill me-2"></i> Пътници</span>
            <button type="button" class="btn btn-sm btn-light text-success fw-semibold" id="addPassengerBtn">
                <i class="bi bi-person-plus-fill me-1"></i> Добави пътник
            </button>
        </div>
        <div class="card-body" id="passengersContainer">
            @if (Model.Passengers is not null)
                {
                    @for (int i = 0; i < Model.Passengers.Count; i++)
            {
                <div class="passenger-entry border rounded p-3 mb-3 bg-light position-relative" data-index="@i">
                    <div class="d-flex justify-content-between align-items-center mb-3">
                        <h6 class="mb-0 text-success"><i class="bi bi-person-badge me-2"></i>Пътник <span class="passenger-number">@(i + 1)</span></h6>
                        @if (i > 0)
                        {
                            <button type="button" class="btn btn-sm btn-outline-danger remove-passenger">
                                <i class="bi bi-trash3"></i> Премахни
                            </button>
                        }
                    </div>
                    <div class="row g-3">
                        <div class="col-md-4">
                            <label class="form-label">Собствено име <span class="text-danger">*</span></label>
                            <input name="Passengers[@i].FirstName" class="form-control"
                                   value="@Model.Passengers[i].FirstName" placeholder="Иван" />
                            <span class="text-danger small field-validation-valid"
                                  data-valmsg-for="Passengers[@i].FirstName"></span>
                        </div>
                        <div class="col-md-4">
                            <label class="form-label">Бащино име <span class="text-danger">*</span></label>
                            <input name="Passengers[@i].MiddleName" class="form-control"
                                   value="@Model.Passengers[i].MiddleName" placeholder="Петров" />
                            <span class="text-danger small field-validation-valid"
                                  data-valmsg-for="Passengers[@i].MiddleName"></span>
                        </div>
                        <div class="col-md-4">
                            <label class="form-label">Фамилно име <span class="text-danger">*</span></label>
                            <input name="Passengers[@i].LastName" class="form-control"
                                   value="@Model.Passengers[i].LastName" placeholder="Георгиев" />
                            <span class="text-danger small field-validation-valid"
                                  data-valmsg-for="Passengers[@i].LastName"></span>
                        </div>
                        <div class="col-md-4">
                            <label class="form-label">ЕГН <span class="text-danger">*</span></label>
                            <input name="Passengers[@i].EGN" class="form-control"
                                   value="@Model.Passengers[i].EGN" placeholder="0000000000" maxlength="10" />
                            <span class="text-danger small field-validation-valid"
                                  data-valmsg-for="Passengers[@i].EGN"></span>
                        </div>
                        <div class="col-md-4">
                            <label class="form-label">Телефонен номер <span class="text-danger">*</span></label>
                            <input name="Passengers[@i].PhoneNumber" class="form-control"
                                   value="@Model.Passengers[i].PhoneNumber" placeholder="+359 88 888 8888" />
                            <span class="text-danger small field-validation-valid"
                                  data-valmsg-for="Passengers[@i].PhoneNumber"></span>
                        </div>
                        <div class="col-md-4">
                            <label class="form-label">Националност <span class="text-danger">*</span></label>
                            <input name="Passengers[@i].Nationality" class="form-control"
                                   value="@Model.Passengers[i].Nationality" placeholder="Българска" />
                            <span class="text-danger small field-validation-valid"
                                  data-valmsg-for="Passengers[@i].Nationality"></span>
                        </div>
                    </div>
                </div>
            }
                }
            </div>
    </div>

    <div class="d-flex gap-2 mb-5">
        <button type="submit" class="btn btn-primary px-4">
            <i class="bi bi-plus-lg me-1"></i> Създай резервация
        </button>
        <a asp-action="Index" class="btn btn-outline-secondary">Отказ</a>
    </div>

</form>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }

    <script>
        // ── Flight info lookup ──────────────────────────────────────────────────
        const flightData = @Html.Raw(ViewBag.FlightsJson ?? "{}");

        document.getElementById('flightSelect').addEventListener('change', function () {
            const id = this.value;
            const info = flightData[id];
            const panel = document.getElementById('flightInfo');
            if (info) {
                document.getElementById('departureCity').textContent = info.departureCity ?? '—';
                document.getElementById('arrivalCity').textContent   = info.arrivalCity    ?? '—';
                document.getElementById('flightDate').textContent    = info.flightDate     ?? '—';
                panel.style.removeProperty('display');
                panel.style.display = 'flex';
            } else {
                panel.style.display = 'none';
            }
        });

        // ── Dynamic passengers ─────────────────────────────────────────────────
        document.getElementById('addPassengerBtn').addEventListener('click', function () {
            // Calculate count dynamically based on DOM instead of a static variable
            const passengerCount = document.querySelectorAll('.passenger-entry').length;
            const i = passengerCount;
        
            const html = `
                <div class="passenger-entry border rounded p-3 mb-3 bg-light position-relative">
                    <div class="d-flex justify-content-between align-items-center mb-3">
                        <h6 class="mb-0 text-success"><i class="bi bi-person-badge me-2"></i>Пътник <span class="passenger-number">${i + 1}</span></h6>
                        <button type="button" class="btn btn-sm btn-outline-danger remove-passenger">
                            <i class="bi bi-trash3"></i> Премахни
                        </button>
                    </div>
                    <div class="row g-3">
                        <div class="col-md-4">
                            <label class="form-label">Собствено име <span class="text-danger">*</span></label>
                            <input name="Passengers[${i}].FirstName" class="form-control" placeholder="Иван" />
                        </div>
                        <div class="col-md-4">
                            <label class="form-label">Бащино име <span class="text-danger">*</span></label>
                            <input name="Passengers[${i}].MiddleName" class="form-control" placeholder="Петров" />
                        </div>
                        <div class="col-md-4">
                            <label class="form-label">Фамилно име <span class="text-danger">*</span></label>
                            <input name="Passengers[${i}].LastName" class="form-control" placeholder="Георгиев" />
                        </div>
                        <div class="col-md-4">
                            <label class="form-label">ЕГН <span class="text-danger">*</span></label>
                            <input name="Passengers[${i}].EGN" class="form-control" placeholder="0000000000" maxlength="10" />
                        </div>
                        <div class="col-md-4">
                            <label class="form-label">Телефонен номер <span class="text-danger">*</span></label>
                            <input name="Passengers[${i}].PhoneNumber" class="form-control" placeholder="+359 88 888 8888" />
                        </div>
                        <div class="col-md-4">
                            <label class="form-label">Националност <span class="text-danger">*</span></label>
                            <input name="Passengers[${i}].Nationality" class="form-control" placeholder="Българска" />
                        </div>
                    </div>
                </div>`;

            document.getElementById('passengersContainer').insertAdjacentHTML('beforeend', html);
            renumberPassengers();
        });

        document.getElementById('passengersContainer').addEventListener('click', function (e) {
            const btn = e.target.closest('.remove-passenger');
            if (!btn) return;
            btn.closest('.passenger-entry').remove();
            renumberPassengers();
        });

        function renumberPassengers() {
            document.querySelectorAll('.passenger-entry').forEach((el, idx) => {
                el.querySelector('.passenger-number').textContent = idx + 1;
                el.querySelectorAll('input').forEach(inp => {
                    // Safely replaces any index like [0], [1], etc. with the correct current index
                    inp.name = inp.name.replace(/\[\d+\]/, `[${idx}]`);
                });
            });
        }
    </script>
}