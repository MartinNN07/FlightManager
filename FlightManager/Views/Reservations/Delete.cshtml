@model FlightManager.Web.ViewModels.Reservations.ReservationDeleteViewModel

@{
    ViewData["Title"] = "Изтрий резервация";
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <h2>@ViewData["Title"]</h2>
    <a asp-action="Index" class="btn btn-outline-secondary">
        <i class="bi bi-arrow-left"></i> Назад към списъка
    </a>
</div>

<div class="alert alert-warning" role="alert">
    <i class="bi bi-exclamation-triangle-fill"></i>
    Сигурни ли сте, че искате да изтриете тази резервация? Действието е необратимо.
</div>

<div class="row">
    <div class="col-md-6">
        <dl class="row">
            <dt class="col-sm-5">@Html.DisplayNameFor(m => m.Id)</dt>
            <dd class="col-sm-7">@Model.Id</dd>

            <dt class="col-sm-5">@Html.DisplayNameFor(m => m.ContactEmail)</dt>
            <dd class="col-sm-7">@Model.ContactEmail</dd>

            <dt class="col-sm-5">@Html.DisplayNameFor(m => m.CreatedAt)</dt>
            <dd class="col-sm-7">@Model.CreatedAt.ToString("g")</dd>

            <dt class="col-sm-5">@Html.DisplayNameFor(m => m.FlightId)</dt>
            <dd class="col-sm-7">@Model.FlightId</dd>

            <dt class="col-sm-5">@Html.DisplayNameFor(m => m.SeatClass)</dt>
            <dd class="col-sm-7">@Model.SeatClass</dd>

            <dt class="col-sm-5">@Html.DisplayNameFor(m => m.PassengerCount)</dt>
            <dd class="col-sm-7">@Model.PassengerCount</dd>
        </dl>

        <form asp-action="Delete" asp-route-id="@Model.Id" method="post">
            @Html.AntiForgeryToken()

            <div class="d-flex gap-2 mt-3">
                <button type="submit" class="btn btn-danger">
                    <i class="bi bi-trash"></i> Да, изтрий
                </button>
                <a asp-action="Index" class="btn btn-outline-secondary">Отказ</a>
            </div>
        </form>
    </div>
</div>