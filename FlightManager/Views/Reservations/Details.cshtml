@model FlightManager.Web.ViewModels.Reservations.ReservationDetailsViewModel

@{
    ViewData["Title"] = "Детайли за резервация";
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <h2>@ViewData["Title"]</h2>
    <a asp-action="Index" class="btn btn-outline-secondary">
        <i class="bi bi-arrow-left"></i> Назад към списъка
    </a>
</div>

<div class="row">
    <div class="col-md-6">
        <dl class="row">
            <dt class="col-sm-5">@Html.DisplayNameFor(m => m.Id)</dt>
            <dd class="col-sm-7">@Model.Id</dd>

            <dt class="col-sm-5">@Html.DisplayNameFor(m => m.ContactEmail)</dt>
            <dd class="col-sm-7">@Model.ContactEmail</dd>

            <dt class="col-sm-5">@Html.DisplayNameFor(m => m.CreatedAt)</dt>
            <dd class="col-sm-7">@Model.CreatedAt.ToString("g")</dd>

            <dt class="col-sm-5">@Html.DisplayNameFor(m => m.FlightId)</dt>
            <dd class="col-sm-7">@Model.FlightId</dd>

            <dt class="col-sm-5">@Html.DisplayNameFor(m => m.SeatClass)</dt>
            <dd class="col-sm-7">@Model.SeatClass</dd>
        </dl>

        @if (User.IsInRole("Admin"))
        {
            <div class="d-flex gap-2 mt-3">
                <a asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-outline-warning">
                    <i class="bi bi-pencil"></i> Редактирай
                </a>
                <a asp-action="Delete" asp-route-id="@Model.Id" class="btn btn-outline-danger">
                    <i class="bi bi-trash"></i> Изтрий
                </a>
            </div>
        }
    </div>

    <div class="col-md-6">
        <h4>@Html.DisplayNameFor(m => m.PassengerNames)</h4>
        @if (Model.PassengerNames == null || !Model.PassengerNames.Any())
        {
            <div class="text-muted">Няма прикачени пътници към тази резервация.</div>
        }
        else
        {
            <ul class="list-group">
                @foreach (var passenger in Model.PassengerNames)
                {
                    <li class="list-group-item">@passenger</li>
                }
            </ul>
        }
    </div>
</div>