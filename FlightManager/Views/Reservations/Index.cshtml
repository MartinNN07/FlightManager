@model IEnumerable<FlightManager.Web.ViewModels.Reservations.ReservationIndexViewModel>

@{
    ViewData["Title"] = "Резервации";
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <h2>@ViewData["Title"]</h2>
</div>

@if (TempData["Success"] is string successMsg)
{
    <div class="alert alert-success alert-dismissible fade show" role="alert">
        @successMsg
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}

@if (!Model.Any())
{
    <div class="alert alert-info">Няма намерени резервации.</div>
}
else
{
    <table class="table table-striped table-hover">
        <thead class="table-dark">
            <tr>
                <th>@Html.DisplayNameFor(m => m.First().Id)</th>
                <th>@Html.DisplayNameFor(m => m.First().ContactEmail)</th>
                <th>@Html.DisplayNameFor(m => m.First().CreatedAt)</th>
                <th>@Html.DisplayNameFor(m => m.First().FlightId)</th>
                <th>@Html.DisplayNameFor(m => m.First().SeatClass)</th>
                <th>@Html.DisplayNameFor(m => m.First().PassengerCount)</th>
                <th>Действия</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var reservation in Model)
            {
                <tr>
                    <td>@reservation.Id</td>
                    <td>@reservation.ContactEmail</td>
                    <td>@reservation.CreatedAt.ToString("dd.MM.yyyy HH:mm")</td>
                    <td>@reservation.FlightId</td>
                    <td>@reservation.SeatClass</td>
                    <td>@reservation.PassengerCount</td>
                    <td>
                        <a asp-action="Details" asp-route-id="@reservation.Id"
                           class="btn btn-sm btn-outline-info">Детайли</a>
                    </td>
                </tr>
            }
        </tbody>
    </table>
}
