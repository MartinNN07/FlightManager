@model IEnumerable<FlightManager.Web.ViewModels.Reservations.ReservationIndexViewModel>

@{
    ViewData["Title"] = "Резервации";
    int page = ViewBag.Page != null ? (int)ViewBag.Page : 1;
    int totalPages = ViewBag.TotalPages != null ? (int)ViewBag.TotalPages : 1;
    int totalCount = ViewBag.TotalCount != null ? (int)ViewBag.TotalCount : 0;
    int pageSize = ViewBag.PageSize != null ? (int)ViewBag.PageSize : 10;
    string? filterEmail = ViewBag.FilterEmail as string;
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <h2>@ViewData["Title"]</h2>
</div>

@if (TempData["Success"] is string successMsg)
{
    <div class="alert alert-success alert-dismissible fade show" role="alert">
        @successMsg
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}

<div class="card mb-3 shadow-sm">
    <div class="card-body">
        <form asp-action="Index" method="get" class="row g-2 align-items-end">

            <div class="col-md-4">
                <label class="form-label small fw-semibold">Имейл за контакт</label>
                <div class="input-group input-group-sm">
                    <span class="input-group-text"><i class="bi bi-search"></i></span>
                    <input name="filterEmail"
                           value="@filterEmail"
                           class="form-control form-control-sm"
                           placeholder="Търси по имейл..."
                           autocomplete="off" />
                </div>
            </div>

            <div class="col-md-2">
                <label class="form-label small fw-semibold">Записи на страница</label>
                <select name="pageSize" class="form-select form-select-sm">
                    @foreach (var ps in new[] { 10, 25, 50 })
                    {
                        <option value="@ps" selected="@(pageSize == ps)">@ps</option>
                    }
                </select>
            </div>

            <div class="col-auto d-flex gap-1">
                <button type="submit" class="btn btn-primary btn-sm">🔍 Търси</button>
                <a asp-action="Index" class="btn btn-outline-secondary btn-sm" title="Изчисти филтрите">✕ Изчисти</a>
            </div>

        </form>
    </div>
</div>

<p class="text-muted small">
    Намерени резервации: <strong>@totalCount</strong>
</p>

@if (!Model.Any())
{
    <div class="alert alert-info">Няма намерени резервации по зададените критерии.</div>
}
else
{
    <div class="table-responsive">
        <table class="table table-striped table-hover align-middle">
            <thead class="table-dark">
                <tr>
                    <th>@Html.DisplayNameFor(m => m.First().Id)</th>
                    <th>@Html.DisplayNameFor(m => m.First().ContactEmail)</th>
                    <th>@Html.DisplayNameFor(m => m.First().CreatedAt)</th>
                    <th>@Html.DisplayNameFor(m => m.First().FlightId)</th>
                    <th>@Html.DisplayNameFor(m => m.First().SeatClass)</th>
                    <th>@Html.DisplayNameFor(m => m.First().PassengerCount)</th>
                    <th>Действия</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var reservation in Model)
                {
                    <tr>
                        <td>@reservation.Id</td>
                        <td>@reservation.ContactEmail</td>
                        <td>@reservation.CreatedAt.ToString("dd.MM.yyyy HH:mm")</td>
                        <td>
                            <a asp-controller="Flights" asp-action="Details" asp-route-id="@reservation.FlightId">
                                @reservation.FlightId
                            </a>
                        </td>
                        <td>
                            @if (reservation.SeatClass == FlightManager.Data.Models.SeatingClass.Business)
                            {
                                <span class="badge bg-warning text-dark">Бизнес</span>
                            }
                            else
                            {
                                <span class="badge bg-secondary">Икономична</span>
                            }
                        </td>
                        <td>@reservation.PassengerCount</td>
                        <td>
                            <a asp-action="Details" asp-route-id="@reservation.Id"
                               class="btn btn-sm btn-outline-info">Детайли</a>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>

    @if (totalPages > 1)
    {
        <nav aria-label="Странициране">
            <ul class="pagination pagination-sm justify-content-center">

                <li class="page-item @(page <= 1 ? "disabled" : "")">
                    <a class="page-link"
                       asp-action="Index"
                       asp-route-filterEmail="@filterEmail"
                       asp-route-pageSize="@pageSize"
                       asp-route-page="@(page - 1)">‹ Назад</a>
                </li>

                @for (int i = 1; i <= totalPages; i++)
                {
                    <li class="page-item @(i == page ? "active" : "")">
                        <a class="page-link"
                           asp-action="Index"
                           asp-route-filterEmail="@filterEmail"
                           asp-route-pageSize="@pageSize"
                           asp-route-page="@i">@i</a>
                    </li>
                }

                <li class="page-item @(page >= totalPages ? "disabled" : "")">
                    <a class="page-link"
                       asp-action="Index"
                       asp-route-filterEmail="@filterEmail"
                       asp-route-pageSize="@pageSize"
                       asp-route-page="@(page + 1)">Напред ›</a>
                </li>

            </ul>
        </nav>
    }
}
