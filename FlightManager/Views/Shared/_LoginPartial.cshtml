@using Microsoft.AspNetCore.Identity
@using FlightManager.Data.Models
@inject SignInManager<User> SignInManager
@inject UserManager<User> UserManager

@if (SignInManager.IsSignedIn(User))
{
    var currentUser = await UserManager.GetUserAsync(User);
    var isAdmin = await UserManager.IsInRoleAsync(currentUser!, "Admin");
    var roleBadge = isAdmin ? "danger" : "secondary";
    var roleLabel = isAdmin ? "Admin" : "Служител";

    <ul class="navbar-nav align-items-md-center gap-md-1">
        <li class="nav-item">
            <span class="nav-link text-white-50 small">
                👤 <strong class="text-white">@currentUser?.FirstName @currentUser?.LastName</strong>
                <span class="badge bg-@roleBadge ms-1">@roleLabel</span>
            </span>
        </li>
        <li class="nav-item">
            <form asp-controller="Account" asp-action="Logout" method="post" class="d-inline">
                @Html.AntiForgeryToken()
                <button type="submit" class="btn btn-outline-light btn-sm">
                    <i class="bi bi-box-arrow-right"></i> Изход
                </button>
            </form>
        </li>
    </ul>
}
else
{
    <ul class="navbar-nav align-items-md-center gap-md-1">
        <li class="nav-item">
            <a class="nav-link" asp-controller="Account" asp-action="Login">
                <i class="bi bi-box-arrow-in-right"></i> Вход
            </a>
        </li>
        <li class="nav-item">
            <a class="btn btn-outline-light btn-sm" asp-controller="Account" asp-action="Register">
                Регистрация
            </a>
        </li>
    </ul>
}
