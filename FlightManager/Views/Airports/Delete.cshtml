@model FlightManager.Web.ViewModels.Airports.AirportDeleteViewModel

@{
    ViewData["Title"] = $"Изтрий летище {Model.IataCode}";
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <h2>@ViewData["Title"]</h2>
    <a asp-action="Index" class="btn btn-outline-secondary">← Назад към списъка</a>
</div>

<div class="alert alert-warning" role="alert">
    <i class="bi bi-exclamation-triangle-fill"></i>
    Сигурни ли сте, че искате да изтриете това летище? Действието е необратимо.
    @if (Model.DepartingFlightsCount > 0 || Model.ArrivingFlightsCount > 0)
    {
        <br />
        <strong>⚠️ Внимание: Летището е свързано с @(Model.DepartingFlightsCount + Model.ArrivingFlightsCount) полета!</strong>
    }
</div>

<div class="row">
    <div class="col-md-6">
        <dl class="row">
            <dt class="col-sm-5">@Html.DisplayNameFor(m => m.IataCode)</dt>
            <dd class="col-sm-7">
                <span class="badge bg-secondary fs-6">@Model.IataCode</span>
            </dd>

            <dt class="col-sm-5">@Html.DisplayNameFor(m => m.AirportName)</dt>
            <dd class="col-sm-7">@Model.AirportName</dd>

            <dt class="col-sm-5">@Html.DisplayNameFor(m => m.City)</dt>
            <dd class="col-sm-7">@Model.City</dd>

            <dt class="col-sm-5">@Html.DisplayNameFor(m => m.Country)</dt>
            <dd class="col-sm-7">@Model.Country</dd>

            <dt class="col-sm-5">@Html.DisplayNameFor(m => m.DepartingFlightsCount)</dt>
            <dd class="col-sm-7">@Model.DepartingFlightsCount</dd>

            <dt class="col-sm-5">@Html.DisplayNameFor(m => m.ArrivingFlightsCount)</dt>
            <dd class="col-sm-7">@Model.ArrivingFlightsCount</dd>
        </dl>

        <form asp-action="Delete" asp-route-id="@Model.IataCode" method="post">
            @Html.AntiForgeryToken()

            <div class="d-flex gap-2 mt-3">
                <button type="submit" class="btn btn-danger">
                    <i class="bi bi-trash"></i> Да, изтрий
                </button>
                <a asp-action="Index" class="btn btn-outline-secondary">Отказ</a>
            </div>
        </form>
    </div>
</div>
