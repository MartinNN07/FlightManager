@model FlightManager.Web.ViewModels.Airports.AirportDetailsViewModel

@{
    ViewData["Title"] = $"Летище {Model.IataCode}";
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <h2>🌍 Летище <strong>@Model.IataCode</strong></h2>
    <a asp-action="Index" class="btn btn-outline-secondary">← Назад към списъка</a>
</div>

<div class="row g-3 mb-4">
    <div class="col-md-6">
        <div class="card h-100 shadow-sm">
            <div class="card-header fw-bold bg-dark text-white">Информация за летището</div>
            <div class="card-body">
                <dl class="row mb-0">
                    <dt class="col-sm-5">@Html.DisplayNameFor(m => m.IataCode)</dt>
                    <dd class="col-sm-7">
                        <span class="badge bg-secondary fs-6">@Model.IataCode</span>
                    </dd>

                    <dt class="col-sm-5">@Html.DisplayNameFor(m => m.AirportName)</dt>
                    <dd class="col-sm-7">@Model.AirportName</dd>

                    <dt class="col-sm-5">@Html.DisplayNameFor(m => m.City)</dt>
                    <dd class="col-sm-7">@Model.City</dd>

                    <dt class="col-sm-5">@Html.DisplayNameFor(m => m.Country)</dt>
                    <dd class="col-sm-7">@Model.Country</dd>
                </dl>
            </div>
        </div>
    </div>
</div>

@if (User.IsInRole("Admin"))
{
    <div class="d-flex gap-2">
        <a asp-action="Edit" asp-route-id="@Model.IataCode" class="btn btn-outline-warning">
            <i class="bi bi-pencil"></i> Редактирай
        </a>
        <a asp-action="Delete" asp-route-id="@Model.IataCode" class="btn btn-outline-danger">
            <i class="bi bi-trash"></i> Изтрий
        </a>
    </div>
}
