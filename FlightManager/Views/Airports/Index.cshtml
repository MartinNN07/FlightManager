@model IEnumerable<FlightManager.Web.ViewModels.Airports.AirportIndexViewModel>

@{
    ViewData["Title"] = "Летища";
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <h2>@ViewData["Title"]</h2>
    @if (User.IsInRole("Admin"))
    {
        <a asp-action="Create" class="btn btn-primary">
            <i class="bi bi-plus-lg"></i> Добави летище
        </a>
    }
</div>

@if (TempData["Success"] is string successMsg)
{
    <div class="alert alert-success alert-dismissible fade show" role="alert">
        @successMsg
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}

@if (!Model.Any())
{
    <div class="alert alert-info">Няма намерени летища.</div>
}
else
{
    <table class="table table-striped table-hover align-middle">
        <thead class="table-dark">
            <tr>
                <th>@Html.DisplayNameFor(m => m.First().IataCode)</th>
                <th>@Html.DisplayNameFor(m => m.First().AirportName)</th>
                <th>@Html.DisplayNameFor(m => m.First().City)</th>
                <th>@Html.DisplayNameFor(m => m.First().Country)</th>
                <th>Действия</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var airport in Model)
            {
                <tr>
                    <td><span class="badge bg-secondary fs-6">@airport.IataCode</span></td>
                    <td>@airport.AirportName</td>
                    <td>@airport.City</td>
                    <td>@airport.Country</td>
                    <td>
                        <a asp-action="Details" asp-route-id="@airport.IataCode"
                           class="btn btn-sm btn-outline-info">Детайли</a>

                        @if (User.IsInRole("Admin"))
                        {
                            <a asp-action="Edit" asp-route-id="@airport.IataCode"
                               class="btn btn-sm btn-outline-warning ms-1">Редактирай</a>

                            <a asp-action="Delete" asp-route-id="@airport.IataCode"
                               class="btn btn-sm btn-outline-danger ms-1">Изтрий</a>
                        }
                    </td>
                </tr>
            }
        </tbody>
    </table>
}
