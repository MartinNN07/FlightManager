@model FlightManager.Web.ViewModels.Airports.AirportCreateViewModel

@{
    ViewData["Title"] = "Добави летище";
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <h2>@ViewData["Title"]</h2>
    <a asp-action="Index" class="btn btn-outline-secondary">← Назад към списъка</a>
</div>

<div class="row">
    <div class="col-md-6">
        <form asp-action="Create" method="post">
            @Html.AntiForgeryToken()

            <div asp-validation-summary="ModelOnly" class="alert alert-danger" role="alert"></div>

            <div class="mb-3">
                <label asp-for="IataCode" class="form-label fw-semibold"></label>
                <input asp-for="IataCode" class="form-control" placeholder="напр. SOF"
                       maxlength="3" style="text-transform:uppercase" />
                <span asp-validation-for="IataCode" class="text-danger small"></span>
                <div class="form-text">Точно 3 главни букви (напр. SOF, LHR, CDG)</div>
            </div>

            <div class="mb-3">
                <label asp-for="AirportName" class="form-label fw-semibold"></label>
                <input asp-for="AirportName" class="form-control" placeholder="напр. Летище София" />
                <span asp-validation-for="AirportName" class="text-danger small"></span>
            </div>

            <div class="mb-3">
                <label asp-for="City" class="form-label fw-semibold"></label>
                <input asp-for="City" class="form-control" placeholder="напр. София" />
                <span asp-validation-for="City" class="text-danger small"></span>
            </div>

            <div class="mb-3">
                <label asp-for="Country" class="form-label fw-semibold"></label>
                <input asp-for="Country" class="form-control" placeholder="напр. България" />
                <span asp-validation-for="Country" class="text-danger small"></span>
            </div>

            <div class="d-flex gap-2">
                <button type="submit" class="btn btn-primary">
                    <i class="bi bi-plus-lg"></i> Създай
                </button>
                <a asp-action="Index" class="btn btn-outline-secondary">Отказ</a>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    @{ await Html.RenderPartialAsync("_ValidationScriptsPartial"); }
}
