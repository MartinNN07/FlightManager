@model IEnumerable<FlightManager.Web.ViewModels.Flights.FlightIndexViewModel>
@{
    ViewData["Title"] = "Полети";
    int page = (int)ViewBag.Page;
    int totalPages = (int)ViewBag.TotalPages;
    int totalCount = (int)ViewBag.TotalCount;
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <h2>✈️ @ViewData["Title"]</h2>
    @if (User.IsInRole("Admin"))
    {
        <a asp-action="Create" class="btn btn-primary">
            <i class="bi bi-plus-lg"></i> Нов полет
        </a>
    }
</div>

@if (TempData["Success"] is string msg)
{
    <div class="alert alert-success alert-dismissible fade show">
        @msg <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}

<div class="card mb-3 shadow-sm">
    <div class="card-body">
        <form asp-action="Index" method="get" class="row g-2 align-items-end">
            <div class="col-md-2">
                <label class="form-label small fw-semibold">От (IATA)</label>
                <input name="fromIata" value="@ViewBag.FromIata" class="form-control form-control-sm"
                       placeholder="напр. SOF" maxlength="3" style="text-transform:uppercase" />
            </div>
            <div class="col-md-2">
                <label class="form-label small fw-semibold">До (IATA)</label>
                <input name="toIata" value="@ViewBag.ToIata" class="form-control form-control-sm"
                       placeholder="напр. LHR" maxlength="3" style="text-transform:uppercase" />
            </div>
            <div class="col-md-2">
                <label class="form-label small fw-semibold">Дата</label>
                <input name="date" value="@ViewBag.Date" type="date" class="form-control form-control-sm" />
            </div>
            <div class="col-md-2">
                <label class="form-label small fw-semibold">Сортиране</label>
                <select name="sortBy" class="form-select form-select-sm">
                    <option value="" selected="@(ViewBag.SortBy == null)">По дата ↑</option>
                    <option value="departure_desc" selected="@(ViewBag.SortBy == "departure_desc")">По дата ↓</option>
                    <option value="from" selected="@(ViewBag.SortBy == "from")">По произход</option>
                    <option value="to" selected="@(ViewBag.SortBy == "to")">По дестинация</option>
                </select>
            </div>
            <div class="col-md-2">
                <label class="form-label small fw-semibold">Записи</label>
                <select name="pageSize" class="form-select form-select-sm">
                    @foreach (var ps in new[] { 10, 25, 50 })
                    {
                        <option value="@ps" selected="@((int)ViewBag.PageSize == ps)">@ps на страница</option>
                    }
                </select>
            </div>
            <div class="col-md-2 d-flex gap-1">
                <button type="submit" class="btn btn-primary btn-sm flex-grow-1">🔍 Търси</button>
                <a asp-action="Index" class="btn btn-outline-secondary btn-sm">✕</a>
            </div>
        </form>
    </div>
</div>

<p class="text-muted small">Намерени полети: <strong>@totalCount</strong></p>

@if (!Model.Any())
{
    <div class="alert alert-info">Няма намерени полети по зададените критерии.</div>
}
else
{
    <div class="table-responsive">
        <table class="table table-striped table-hover align-middle">
            <thead class="table-dark">
                <tr>
                    <th>Номер</th>
                    <th>От</th>
                    <th>До</th>
                    <th>Излитане</th>
                    <th>Самолет</th>
                    <th>Икон. места</th>
                    <th>Бизнес места</th>
                    <th></th>
                </tr>
            </thead>
            <tbody>
                @foreach (var f in Model)
                {
                    <tr>
                        <td><strong>@f.FlightNumber</strong></td>
                        <td>
                            <span class="badge bg-secondary">@f.DepartureIata</span>
                            <small class="d-block text-muted">@f.DepartureCity</small>
                        </td>
                        <td>
                            <span class="badge bg-secondary">@f.LandingIata</span>
                            <small class="d-block text-muted">@f.LandingCity</small>
                        </td>
                        <td>@f.DepartureTime.ToString("dd.MM.yyyy HH:mm")</td>
                        <td><small>@f.AirplaneModel</small></td>
                        <td>
                            @if (f.AvailableEconomySeats > 0)
                            {
                                <span class="badge bg-success">@f.AvailableEconomySeats</span>
                            }
                            else
                            {
                                <span class="badge bg-danger">0</span>
                            }
                        </td>
                        <td>
                            @if (f.AvailableBusinessSeats > 0)
                            {
                                <span class="badge bg-success">@f.AvailableBusinessSeats</span>
                            }
                            else
                            {
                                <span class="badge bg-danger">0</span>
                            }
                        </td>
                        <td>
                            <a asp-action="Details" asp-route-id="@f.FlightNumber"
                               class="btn btn-sm btn-outline-info">Детайли</a>
                            @if (User.IsInRole("Admin"))
                            {
                                <a asp-action="Edit" asp-route-id="@f.FlightNumber"
                                   class="btn btn-sm btn-outline-warning ms-1">Редактирай</a>
                                <a asp-action="Delete" asp-route-id="@f.FlightNumber"
                                   class="btn btn-sm btn-outline-danger ms-1">Изтрий</a>
                            }
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>

    @if (totalPages > 1)
    {
        <nav>
            <ul class="pagination pagination-sm justify-content-center">
                <li class="page-item @(page <= 1 ? "disabled" : "")">
                    <a class="page-link" asp-action="Index"
                       asp-route-page="@(page - 1)"
                       asp-route-pageSize="@ViewBag.PageSize"
                       asp-route-fromIata="@ViewBag.FromIata"
                       asp-route-toIata="@ViewBag.ToIata"
                       asp-route-date="@ViewBag.Date"
                       asp-route-sortBy="@ViewBag.SortBy">‹ Назад</a>
                </li>

                @for (int i = 1; i <= totalPages; i++)
                {
                    <li class="page-item @(i == page ? "active" : "")">
                        <a class="page-link" asp-action="Index"
                           asp-route-page="@i"
                           asp-route-pageSize="@ViewBag.PageSize"
                           asp-route-fromIata="@ViewBag.FromIata"
                           asp-route-toIata="@ViewBag.ToIata"
                           asp-route-date="@ViewBag.Date"
                           asp-route-sortBy="@ViewBag.SortBy">@i</a>
                    </li>
                }

                <li class="page-item @(page >= totalPages ? "disabled" : "")">
                    <a class="page-link" asp-action="Index"
                       asp-route-page="@(page + 1)"
                       asp-route-pageSize="@ViewBag.PageSize"
                       asp-route-fromIata="@ViewBag.FromIata"
                       asp-route-toIata="@ViewBag.ToIata"
                       asp-route-date="@ViewBag.Date"
                       asp-route-sortBy="@ViewBag.SortBy">Напред ›</a>
                </li>
            </ul>
        </nav>
    }
}
