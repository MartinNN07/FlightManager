@model IEnumerable<FlightManager.Web.ViewModels.Flights.FlightIndexViewModel>
@{
    ViewData["Title"] = "Полети";
    int page = (int)ViewBag.Page;
    int totalPages = (int)ViewBag.TotalPages;
    int totalCount = (int)ViewBag.TotalCount;
    bool isAdmin = User.IsInRole("Admin");
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <h2>✈️ @ViewData["Title"]</h2>
    @if (isAdmin)
    {
        <a asp-action="Create" class="btn btn-primary">
            <i class="bi bi-plus-lg"></i> Нов полет
        </a>
    }
</div>

@if (TempData["Success"] is string msg)
{
    <div class="alert alert-success alert-dismissible fade show">
        @msg <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}

<div class="card mb-3 shadow-sm">
    <div class="card-body">
        <form asp-action="Index" method="get" id="filterForm" class="row g-2 align-items-end">

            <div class="col-md-3 position-relative">
                <label class="form-label small fw-semibold">От</label>
                <div class="input-group input-group-sm">
                    <span class="input-group-text"><i class="bi bi-search"></i></span>
                    <input id="departureTermInput"
                           name="departureTerm"
                           value="@ViewBag.DepartureTerm"
                           class="form-control form-control-sm"
                           placeholder="От"
                           autocomplete="off" />
                </div>
            </div>

            <div class="col-md-3 position-relative">
                <label class="form-label small fw-semibold">До</label>
                <div class="input-group input-group-sm">
                    <span class="input-group-text"><i class="bi bi-search"></i></span>
                    <input id="arrivalTermInput"
                           name="arrivalTerm"
                           value="@ViewBag.ArrivalTerm"
                           class="form-control form-control-sm"
                           placeholder="До"
                           autocomplete="off" />
                </div>
            </div>

            <div class="col-md-2">
                <label class="form-label small fw-semibold">Дата</label>
                <input name="date" value="@ViewBag.Date" type="date" class="form-control form-control-sm" />
            </div>

            <div class="col-md-2">
                <label class="form-label small fw-semibold">Сортиране</label>
                <select name="sortBy" id="sortBySelect" class="form-select form-select-sm">
                    <option value="" selected="@(ViewBag.SortBy == null)">По дата ↑</option>
                    <option value="departure_desc" selected="@(ViewBag.SortBy == "departure_desc")">По дата ↓</option>
                    <option value="from" selected="@(ViewBag.SortBy == "from")">По произход</option>
                    <option value="to" selected="@(ViewBag.SortBy == "to")">По дестинация</option>
                </select>
            </div>

            <div class="col-md-1">
                <label class="form-label small fw-semibold">Записи</label>
                <select name="pageSize" id="pageSizeSelect" class="form-select form-select-sm">
                    @foreach (var ps in new[] { 10, 25, 50 })
                    {
                        <option value="@ps" selected="@((int)ViewBag.PageSize == ps)">@ps</option>
                    }
                </select>
            </div>

            <div class="col-md-1 d-flex gap-1">
                <button type="submit" class="btn btn-primary btn-sm flex-grow-1">🔍</button>
                <a asp-action="Index" class="btn btn-outline-secondary btn-sm" title="Изчисти филтрите">✕</a>
            </div>

        </form>
    </div>
</div>

<p class="text-muted small">
    Намерени полети: <strong id="resultCount">@totalCount</strong>
    <span id="liveIndicator" class="ms-2 text-primary" style="display:none">
        <span class="spinner-border spinner-border-sm"></span> Търсене…
    </span>
</p>

<div id="noResults" class="alert alert-info @(Model.Any() ? "d-none" : "")">
    Няма намерени полети по зададените критерии.
</div>

<div id="tableWrapper" class="table-responsive @(!Model.Any() ? "d-none" : "")">
    <table class="table table-striped table-hover align-middle">
        <thead class="table-dark">
            <tr>
                <th>Номер</th>
                <th>От</th>
                <th>До</th>
                <th>Излитане</th>
                <th>Самолет</th>
                <th>Икон. места</th>
                <th>Бизнес места</th>
                <th></th>
            </tr>
        </thead>
        <tbody id="flightsBody">
            @foreach (var f in Model)
            {
                <tr>
                    <td><strong>@f.FlightNumber</strong></td>
                    <td>
                        <span class="badge bg-secondary">@f.DepartureIata</span>
                        <small class="d-block text-muted">@f.DepartureCity</small>
                    </td>
                    <td>
                        <span class="badge bg-secondary">@f.LandingIata</span>
                        <small class="d-block text-muted">@f.LandingCity</small>
                    </td>
                    <td>@f.DepartureTime.ToString("dd.MM.yyyy HH:mm")</td>
                    <td><small>@f.AirplaneModel</small></td>
                    <td>
                        @if (f.AvailableEconomySeats > 0)
                        {
                            <span class="badge bg-success">@f.AvailableEconomySeats</span>
                        }
                        else
                        {
                            <span class="badge bg-danger">0</span>
                        }
                    </td>
                    <td>
                        @if (f.AvailableBusinessSeats > 0)
                        {
                            <span class="badge bg-success">@f.AvailableBusinessSeats</span>
                        }
                        else
                        {
                            <span class="badge bg-danger">0</span>
                        }
                    </td>
                    <td class="text-nowrap">
                        <a asp-action="Details" asp-route-id="@f.FlightNumber"
                           class="btn btn-sm btn-outline-info">Детайли</a>

                        @if (!isAdmin)
                        {
                            <a asp-controller="Reservations" asp-action="Create"
                               asp-route-flightId="@f.FlightNumber"
                               class="btn btn-sm btn-success ms-1">🎫 Резервирай</a>
                        }

                        @if (isAdmin)
                        {
                            <a asp-action="Edit" asp-route-id="@f.FlightNumber"
                               class="btn btn-sm btn-outline-warning ms-1">Редактирай</a>
                        }
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>

<nav id="paginationWrapper">
    @if (totalPages > 1)
    {
        <ul class="pagination pagination-sm justify-content-center">
            <li class="page-item @(page <= 1 ? "disabled" : "")">
                <a class="page-link" asp-action="Index"
                   asp-route-page="@(page - 1)"
                   asp-route-pageSize="@ViewBag.PageSize"
                   asp-route-date="@ViewBag.Date"
                   asp-route-sortBy="@ViewBag.SortBy"
                   asp-route-departureTerm="@ViewBag.DepartureTerm"
                   asp-route-arrivalTerm="@ViewBag.ArrivalTerm">‹ Назад</a>
            </li>
            @for (int i = 1; i <= totalPages; i++)
            {
                <li class="page-item @(i == page ? "active" : "")">
                    <a class="page-link" asp-action="Index"
                       asp-route-page="@i"
                       asp-route-pageSize="@ViewBag.PageSize"
                       asp-route-date="@ViewBag.Date"
                       asp-route-sortBy="@ViewBag.SortBy"
                       asp-route-departureTerm="@ViewBag.DepartureTerm"
                       asp-route-arrivalTerm="@ViewBag.ArrivalTerm">@i</a>
                </li>
            }
            <li class="page-item @(page >= totalPages ? "disabled" : "")">
                <a class="page-link" asp-action="Index"
                   asp-route-page="@(page + 1)"
                   asp-route-pageSize="@ViewBag.PageSize"
                   asp-route-date="@ViewBag.Date"
                   asp-route-sortBy="@ViewBag.SortBy"
                   asp-route-departureTerm="@ViewBag.DepartureTerm"
                   asp-route-arrivalTerm="@ViewBag.ArrivalTerm">Напред ›</a>
            </li>
        </ul>
    }
</nav>
