@model FlightManager.Web.ViewModels.Flights.FlightDeleteViewModel
@{
    ViewData["Title"] = $"Изтрий полет {Model.FlightNumber}";
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <h2>@ViewData["Title"]</h2>
    <a asp-action="Index" class="btn btn-outline-secondary">← Назад</a>
</div>

<div class="alert alert-warning">
    <i class="bi bi-exclamation-triangle-fill"></i>
    Сигурни ли сте, че искате да изтриете този полет? Действието е необратимо.
    @if (Model.ReservationCount > 0)
    {
        <br />
    
        <strong>⚠️ Внимание: Полетът има @Model.ReservationCount резервации!</strong>
    }
</div>

<div class="col-md-5">
    <dl class="row">
        <dt class="col-sm-5">Номер</dt>
        <dd class="col-sm-7">@Model.FlightNumber</dd>

        <dt class="col-sm-5">Маршрут</dt>
        <dd class="col-sm-7">@Model.DepartureCity → @Model.LandingCity</dd>

        <dt class="col-sm-5">Излитане</dt>
        <dd class="col-sm-7">@Model.DepartureTime.ToString("dd.MM.yyyy HH:mm")</dd>

        <dt class="col-sm-5">Самолет</dt>
        <dd class="col-sm-7">@Model.AirplaneModel</dd>

        <dt class="col-sm-5">Резервации</dt>
        <dd class="col-sm-7">@Model.ReservationCount</dd>
    </dl>

    <form asp-action="Delete" asp-route-id="@Model.FlightNumber" method="post">
        @Html.AntiForgeryToken()
        <div class="d-flex gap-2">
            <button type="submit" class="btn btn-danger">🗑️ Да, изтрий</button>
            <a asp-action="Index" class="btn btn-outline-secondary">Отказ</a>
        </div>
    </form>
</div>
