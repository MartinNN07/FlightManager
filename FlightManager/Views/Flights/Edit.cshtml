@model FlightManager.Web.ViewModels.Flights.FlightEditViewModel
@{
    ViewData["Title"] = $"Редактирай полет {Model.FlightNumber}";
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <h2>@ViewData["Title"]</h2>
    <a asp-action="Index" class="btn btn-outline-secondary">← Назад</a>
</div>

<div class="row">
    <div class="col-md-7">
        <form asp-action="Edit" asp-route-id="@Model.FlightNumber" method="post">
            @Html.AntiForgeryToken()
            <div asp-validation-summary="ModelOnly" class="alert alert-danger" role="alert"></div>

            <div class="mb-3">
                <label asp-for="FlightNumber" class="form-label fw-semibold"></label>
                <input asp-for="FlightNumber" class="form-control" readonly />
            </div>

            <div class="row">
                <div class="col-md-6 mb-3">
                    <label asp-for="DepartureAirportIataCode" class="form-label fw-semibold"></label>
                    <select asp-for="DepartureAirportIataCode" asp-items="ViewBag.Airports" class="form-select">
                        <option value="">— Изберете —</option>
                    </select>
                    <span asp-validation-for="DepartureAirportIataCode" class="text-danger small"></span>
                </div>
                <div class="col-md-6 mb-3">
                    <label asp-for="LandingAirportIataCode" class="form-label fw-semibold"></label>
                    <select asp-for="LandingAirportIataCode" asp-items="ViewBag.Airports" class="form-select">
                        <option value="">— Изберете —</option>
                    </select>
                    <span asp-validation-for="LandingAirportIataCode" class="text-danger small"></span>
                </div>
            </div>

            <div class="mb-3">
                <label asp-for="AirplaneId" class="form-label fw-semibold"></label>
                <select asp-for="AirplaneId" asp-items="ViewBag.Airplanes" class="form-select">
                    <option value="">— Изберете —</option>
                </select>
                <span asp-validation-for="AirplaneId" class="text-danger small"></span>
            </div>

            <div class="mb-3">
                <label asp-for="PilotName" class="form-label fw-semibold"></label>
                <input asp-for="PilotName" class="form-control" />
                <span asp-validation-for="PilotName" class="text-danger small"></span>
            </div>

            <div class="row">
                <div class="col-md-6 mb-3">
                    <label asp-for="DepartureTime" class="form-label fw-semibold"></label>
                    <input asp-for="DepartureTime"
                           type="datetime-local"
                           class="form-control"
                           value="@Model.DepartureTime.ToString("yyyy-MM-ddTHH:mm")" />
                    <span asp-validation-for="DepartureTime" class="text-danger small"></span>
                </div>
                <div class="col-md-6 mb-3">
                    <label asp-for="LandingTime" class="form-label fw-semibold"></label>
                    <input asp-for="LandingTime"
                           type="datetime-local"
                           class="form-control"
                           value="@Model.LandingTime.ToString("yyyy-MM-ddTHH:mm")" />
                    <span asp-validation-for="LandingTime" class="text-danger small"></span>
                </div>
            </div>

            <div class="d-flex gap-2">
                <button type="submit" class="btn btn-warning">💾 Запази промените</button>
                <a asp-action="Index" class="btn btn-outline-secondary">Отказ</a>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}
