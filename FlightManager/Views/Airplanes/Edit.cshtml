@model FlightManager.Web.ViewModels.Airplane.AirplaneEditViewModel

@{
    ViewData["Title"] = "Редактирай самолет";
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <h2>@ViewData["Title"]</h2>
    <a asp-action="Index" class="btn btn-outline-secondary">
        <i class="bi bi-arrow-left"></i> Назад към списъка
    </a>
</div>

<div class="row">
    <div class="col-md-6">
        <form asp-action="Edit" asp-route-id="@Model.Id" method="post">
            @Html.AntiForgeryToken()

            <div asp-validation-summary="ModelOnly" class="alert alert-danger" role="alert"></div>

            <div class="mb-3">
                <label asp-for="Id" class="form-label"></label>
                <input asp-for="Id" class="form-control" readonly />
            </div>

            <div class="mb-3">
                <label asp-for="Model" class="form-label"></label>
                <input asp-for="Model" class="form-control" />
                <span asp-validation-for="Model" class="text-danger small"></span>
            </div>

            <div class="mb-3">
                <label asp-for="EconomyClassSeats" class="form-label"></label>
                <input asp-for="EconomyClassSeats" class="form-control" type="number" min="1" />
                <span asp-validation-for="EconomyClassSeats" class="text-danger small"></span>
            </div>

            <div class="mb-3">
                <label asp-for="BusinessClassSeats" class="form-label"></label>
                <input asp-for="BusinessClassSeats" class="form-control" type="number" min="0" />
                <span asp-validation-for="BusinessClassSeats" class="text-danger small"></span>
            </div>

            <div class="d-flex gap-2">
                <button type="submit" class="btn btn-warning">
                    <i class="bi bi-floppy"></i> Запази промените
                </button>
                <a asp-action="Index" class="btn btn-outline-secondary">Отказ</a>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
