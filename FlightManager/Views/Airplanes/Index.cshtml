@model IEnumerable<FlightManager.Web.ViewModels.Airplane.AirplaneIndexViewModel>

@{
    ViewData["Title"] = "Самолети";
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <h2>@ViewData["Title"]</h2>
    @if (User.IsInRole("Admin"))
    {
        <a asp-action="Create" class="btn btn-primary">
            <i class="bi bi-plus-lg"></i> Добави самолет
        </a>
    }
</div>

@if (TempData["Success"] is string successMsg)
{
    <div class="alert alert-success alert-dismissible fade show" role="alert">
        @successMsg
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}

@if (!Model.Any())
{
    <div class="alert alert-info">Няма намерени самолети.</div>
}
else
{
    <table class="table table-striped table-hover">
        <thead class="table-dark">
            <tr>
                <th>@Html.DisplayNameFor(m => m.First().Id)</th>
                <th>@Html.DisplayNameFor(m => m.First().Model)</th>
                <th>@Html.DisplayNameFor(m => m.First().EconomyClassSeats)</th>
                <th>@Html.DisplayNameFor(m => m.First().BusinessClassSeats)</th>
                <th>@Html.DisplayNameFor(m => m.First().TotalSeats)</th>
                <th>Действия</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var airplane in Model)
            {
                <tr>
                    <td>@airplane.Id</td>
                    <td>@airplane.Model</td>
                    <td>@airplane.EconomyClassSeats</td>
                    <td>@airplane.BusinessClassSeats</td>
                    <td>@airplane.TotalSeats</td>
                    <td>
                        <a asp-action="Details" asp-route-id="@airplane.Id"
                           class="btn btn-sm btn-outline-info">Детайли</a>

                        @if (User.IsInRole("Admin"))
                        {
                            <a asp-action="Edit" asp-route-id="@airplane.Id"
                               class="btn btn-sm btn-outline-warning ms-1">Редактирай</a>
                        }
                    </td>
                </tr>
            }
        </tbody>
    </table>
}
